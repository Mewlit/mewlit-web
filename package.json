    "@fontsource/source-code-pro": "5.2.7",
    "@headlessui/tailwindcss": "0.2.2",
    "@headlessui/vue": "1.7.23",
    "@hiratake/textlint-rule-front-matter": "1.1.2",
    "@iconify-json/ph": "1.2.2",
    "@iconify-json/simple-icons": "1.2.91",
    "@nuxt/content": "3.14.0",
    "@nuxt/eslint": "1.16.0",
    "@nuxtjs/seo": "3.4.0",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@resvg/resvg-wasm": "2.6.2",
    "@tailwindcss/typography": "0.5.20",
    "@textlint-rule/textlint-rule-no-unmatched-pair": "2.0.4",
    "@vueuse/core": "14.3.0",
    "@vueuse/nuxt": "14.3.0",
    "autoprefixer": "10.5.2",
    "better-sqlite3": "12.11.1",
    "eslint": "10.7.0",
    "feed": "5.2.1",
    "h3": "1.15.11",
    "lefthook": "2.1.10",
    "nuxt": "4.4.4",
    "nuxt-llms": "0.2.0",
    "postcss": "8.5.16",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "tailwindcss": "3.4.19",
    "textlint": "15.7.1",
    "textlint-filter-rule-allowlist": "4.0.0",
    "textlint-filter-rule-comments": "1.3.0",
    "textlint-rule-no-mixed-zenkaku-and-hankaku-alphabet": "1.0.1",
    "textlint-rule-preset-ja-spacing": "3.0.2",
    "typescript": "6.0.3",
    "ufo": "1.6.4",
    "vue": "3.5.39",
    "vue-router": "5.1.0",
    "vue-tsc": "3.3.5"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint": "pnpm lint:script && pnpm lint:text",
    "lint:fix": "pnpm lint:script:fix && pnpm lint:text:fix",
    "lint:script": "eslint \"**/*.{js,cjs,mjs,ts,cts,mts,vue}\"",
    "lint:script:fix": "eslint \"**/*.{js,cjs,mjs,ts,cts,mts,vue}\" --fix",
    "lint:text": "textlint \"**/*.md\"",
    "lint:text:fix": "textlint \"**/*.md\" --fix",
    "typecheck": "nuxt typecheck",
    "format": "prettier \"**/!(*.md)\" -wu",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@iconify-json/solar": "1.2.5",
    "vue-use-fixed-header": "2.0.3"
  }
